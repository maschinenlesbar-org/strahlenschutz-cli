{
  "name": "@maschinenlesbar.org/strahlenschutz-cli",
  "version": "0.0.2",
  "description": "TypeScript API client and CLI for the open BfS ODL-Info radiation API (imis.bfs.de)",
  "type": "module",
  "bin": {
    "strahlenschutz": "dist/src/cli/index.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "LICENSING.md",
    "CONTRIBUTING.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/test/*.test.js",
    "docs": "typedoc src/index.ts --out out",
    "start": "node dist/src/cli/index.js"
  },
  "keywords": [
    "strahlenschutz",
    "bfs",
    "odl",
    "radiation",
    "environment",
    "germany",
    "cli",
    "api-client"
  ],
  "author": "Sebastian Schürmann <sebs@2xs.org>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maschinenlesbar-org/strahlenschutz-cli.git"
  },
  "bugs": {
    "url": "https://github.com/maschinenlesbar-org/strahlenschutz-cli/issues"
  },
  "homepage": "https://github.com/maschinenlesbar-org/strahlenschutz-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "15.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  }
}
